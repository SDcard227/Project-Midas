# Alpaca Markets — https://alpaca.markets
# Handles real-time price data AND trade execution
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Finnhub — https://finnhub.io
# Handles news sentiment scoring
FINNHUB_API_KEY=your_finnhub_api_key_here

# Anthropic (Claude) — https://console.anthropic.com
# Powers the AI news filter: headline classification + whisper detection.
# Without this key, the AI layer disables itself and the bot still runs.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional — defaults to the cheap/fast tier for high-volume classification.
ANTHROPIC_MODEL=claude-haiku-4-5
# Optional — stronger model for the peer-review fact-checker (runs on few signals).
ANTHROPIC_REVIEW_MODEL=claude-opus-4-8

# SEC EDGAR requires a contact string in the User-Agent. Use your real email.
SEC_CONTACT=Your Name your_email@example.com

# Worker — how often the always-on scanner runs, in seconds (default 300 = 5 min).
SCAN_INTERVAL_SECONDS=300

# StockTwits social chatter (optional). The public API 403s without a token now.
# Get an access token from stocktwits.com developer settings, then set it here.
STOCKTWITS_TOKEN=

# Accounts + Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# Financial Modeling Prep — https://financialmodelingprep.com (free tier)
# Lights up the company-dossier ownership pie AND Congress trades (one key, both).
FMP_API_KEY=

# Email — verification sends. Without these, verify runs in dev mode (shows the link).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@yourdomain.com

# Flask session secret. On Render, render.yaml generates one automatically.
SECRET_KEY=change-me-in-production

# Persistence. Point DB_PATH (+ LEDGER_PATH) at a persistent disk so data survives
# deploys. Render FREE tier has no disk -> use a Postgres via DATABASE_URL instead
# (the brain/db.py seam routes to it once the modules are wired + tested).
DB_PATH=
LEDGER_PATH=
DATABASE_URL=

# Trading is OFF by default. Set to 1 ONLY on a private/authenticated deploy — the
# trade endpoints place (paper) orders on THESE keys, so never expose them publicly.
ENABLE_TRADING=0

# The Funnies — community comic/art submissions.
# UPLOAD_DIR: where uploaded images are stored (point at a persistent disk in prod).
# ADMIN_EMAIL: the account allowed to approve/reject submissions.
UPLOAD_DIR=
ADMIN_EMAIL=
